# Copy to .env in this folder (agent/). Used automatically when you run the agent.

# --- AWS / Bedrock (chat + skill routing uses the same LLM) ---
# Region must match where you enabled models in the Bedrock console (e.g. us-east-1).
AWS_REGION=us-east-1
# Optional if not using aws configure / SSO:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Optional: custom skills folder (default: ./skills next to this directory)
# SKILLS_DIR=

# --- Local HTTP server (python src/main.py) ---
HOST=127.0.0.1
PORT=8080

# Optional: durable LangGraph checkpoints on disk
# LANGGRAPH_CHECKPOINT_SQLITE=.langgraph_checkpoints.sqlite

# Optional: Gateway MCP URL override
# GATEWAY_MCP_URL=
