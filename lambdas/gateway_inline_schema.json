  {
    "name": "get_cost_and_usage",
    "description": "Retrieve AWS cost and usage data. Response includes _period_service_totals.period_total_usd and by_service for the full date range (authoritative). Use omit group_by + DAILY for daily totals in ResultsByTime. Do not use DAILY+SERVICE rows alone for period total. granularity: DAILY|MONTHLY|HOURLY.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "start_date": { "type": "string", "description": "Start date YYYY-MM-DD" },
        "end_date": { "type": "string", "description": "End date YYYY-MM-DD inclusive" },
        "granularity": { "type": "string", "description": "DAILY, MONTHLY, or HOURLY" },
        "group_by": { "type": "string", "description": "Omit or NONE for totals per day/month. SERVICE, REGION, LINKED_ACCOUNT, etc. for breakdown." },
        "filter_expression": { "type": "object", "description": "Cost Explorer Filter JSON" },
        "metric": { "type": "string", "description": "UnblendedCost, BlendedCost, UsageQuantity" }
      },
      "required": ["start_date", "end_date"]
    }
  },
